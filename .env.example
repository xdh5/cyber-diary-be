# Environment variables for backend deployment
DATABASE_URL=sqlite:///./diary.db
PORT=8000
LOG_LEVEL=info
SECRET_KEY=replace-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SMTP settings for email verification
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=your-email@example.com
SMTP_USE_TLS=true

# Google OAuth2 settings
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# Cloudinary settings for image upload
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ByteDance Doubao API
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Chat model used by the tool-calling agent
DOUBAO_CHAT_MODEL=doubao-1-5-thinking-vision-pro-250428
# Ordered fallback list for direct Doubao requests
DOUBAO_MODEL_LIST=doubao-1-5-thinking-vision-pro-250428
# Doubao request read timeout in seconds
DOUBAO_READ_TIMEOUT_SECONDS=45
